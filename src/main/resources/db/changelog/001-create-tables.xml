<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="000-create-sequence" author="developer">
        <createSequence sequenceName="hotel_seq" startValue="1" incrementBy="1"/>
    </changeSet>

    <changeSet id="001-create-hotels-table" author="developer">
        <createTable tableName="hotels">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="brand" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="house_number" type="INT"/>
            <column name="street" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="country" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="post_code" type="VARCHAR(20)"/>
            <column name="phone" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="check_in" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="check_out" type="VARCHAR(10)"/>
        </createTable>
    </changeSet>

    <changeSet id="002-create-hotel-amenities-table" author="developer">
        <createTable tableName="hotel_amenities">
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="amenity" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="hotel_amenities"
            baseColumnNames="hotel_id"
            constraintName="fk_amenities_hotel"
            referencedTableName="hotels"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
